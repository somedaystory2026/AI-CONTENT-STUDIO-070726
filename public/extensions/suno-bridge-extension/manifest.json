{
  "manifest_version": 3,
  "name": "David Melody Suno Bridge",
  "version": "0.4.1",
  "description": "다윗멜로디 AI Studio(localhost 포함)에서 만든 제목/스타일/가사를 Suno.com 사이드패널로 버튼 클릭 시 1회만 전달합니다.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://suno.com/*",
    "*://*.suno.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "<all_urls>"
      ],
      "js": [
        "content-site.js"
      ],
      "run_at": "document_start",
      "exclude_matches": [
        "https://suno.com/*",
        "*://*.suno.com/*"
      ]
    },
    {
      "matches": [
        "https://suno.com/*",
        "*://*.suno.com/*"
      ],
      "js": [
        "content-suno.js"
      ],
      "run_at": "document_end"
    }
  ]
}